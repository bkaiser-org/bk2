{
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,

  // verbose (1 TB log data/per day !), off (none), normal (errors, warnings)
  "js/ts.tsserver.log": "off",
  "js/ts.tsserver.maxMemory": 8192, // Increase to 8GB (default is ~3GB)
  "js/ts.tsserver.experimental.enableProjectDiagnostics": false, // Disable heavy diagnostics for monorepos
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "files.exclude": {
    "**/node_modules": true,
    "**/.nx/cache": true
  },
  // Limit file watching to reduce memory
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/coverage/**": true,
    "**/.nx/**": true,
    "**/.firebase/**": true
  },

// Optimize search to exclude large directories
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.nx": true,
    "**/.firebase": true,
    "**/*.spec.ts": true // Exclude test files if not needed during searches
  },
  "search.followSymlinks": false, // Prevent memory spikes from symlinked node_modules

  // Scope each file to its nearest project's eslint config instead of loading
  // the whole monorepo (+ a workspace-wide TS program) into one server — this
  // is what was causing the "JavaScript heap out of memory" crash.
  "eslint.workingDirectories": [{ "mode": "auto" }],
  // Lint on save only, not on every keystroke — typed linting (@nx flat/angular)
  // is too heavy to re-run on type in a repo this size.
  "eslint.run": "onSave",
  "eslint.probe": ["javascript", "typescript", "html"], // Limit ESLint to relevant file types
  "eslint.enable": true,
  "eslint.validate": ["json"],

  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },

  "prettier.configPath": "./.prettierrc",
  "prettier.ignorePath": "./.prettierignore",

  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },

  "debug.javascript.autoAttachFilter": "smart",

  "terminal.integrated.env.osx": {
    "NVM_DIR": "$HOME/.nvm",
    "PATH": "$HOME/.nvm/versions/node/v20.19.3/bin:$PATH"
  },

  "angular.enable-strict-mode-prompt": false
}
