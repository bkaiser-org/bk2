rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================================
    //  Helpers — authorization is derived from the caller's users/{uid} document,
    //  NOT from custom claims. Custom claims (token.admin / token.contentAdmin /
    //  token.tenantId) are never minted anywhere in this project, so claim-based
    //  checks would always be false. The user doc carries:
    //    - roles:   map<RoleName, bool>   (e.g. { admin: true, contentAdmin: true })
    //    - tenants: string[]              (always exactly one tenant per user)
    //  Every stored model carries tenants: string[]; the 'system' tenant denotes
    //  shared/global data readable by every tenant.
    // ============================================================================

    function signedIn() {
      return request.auth != null;
    }
    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }
    function userExists() {
      return signedIn() && exists(userPath());
    }
    function userData() {
      return get(userPath()).data;
    }
    function callerTenants() {
      return userExists() ? userData().tenants : [];
    }
    function hasRole(role) {
      return userExists() && userData().roles.get(role, false) == true;
    }
    function isAdmin() {
      return hasRole('admin');
    }
    function isPrivileged() {
      return hasRole('privileged') || isAdmin();
    }
    // CMS content (pages/sections/menuItems/categories) is authored in the
    // privileged CMS UI; writes require the content role (M-7).
    function isContentManager() {
      return hasRole('contentAdmin') || isPrivileged();
    }
    // A document belongs to the caller's tenant when their tenant is listed on the
    // document, or when the document is shared via the 'system' tenant.
    function belongsToTenant(data) {
      return data.tenants.hasAny(callerTenants()) || data.tenants.hasAny(['system']);
    }
    function tenantRead() {
      return userExists() && belongsToTenant(resource.data);
    }
    function tenantCreate() {
      return userExists() && belongsToTenant(request.resource.data);
    }
    function tenantUpdate() {
      return userExists() && belongsToTenant(resource.data) && belongsToTenant(request.resource.data);
    }
    function tenantDelete() {
      return userExists() && belongsToTenant(resource.data);
    }

    // ============================================================================
    //  Public read — only what an unauthenticated client genuinely renders.
    //
    //  The public-facing static websites (apps/*-website) do NOT read Firestore
    //  directly — they fetch curated, field-mapped JSON from the publicApi Cloud
    //  Function (server-side, Admin SDK), which is the single public gateway.
    //
    //  The only browser path that reads Firestore anonymously is the PWA's
    //  public/* landing (cms-page PageDispatcher → pages + sections, ungated),
    //  plus the app-config / app-version bootstrap docs. Everything else
    //  (orgs/resources/tags/categories) is loaded by AppStore only after login
    //  (its resources are gated on fbUser), so it must NOT be world-readable.
    //
    //  CMS content (pages/sections/menuItems/categories) writes are content-role
    //  gated (M-7).
    // ============================================================================

    match /app-config/{tenant} {
      allow read: if true;
      allow write: if isPrivileged();                 // app configuration is admin territory
    }
    match /app-version/{doc} {
      allow read: if true;
      allow write: if false;                          // updated out-of-band / by admin tooling
    }
    // CMS content rendered by the anonymous PWA landing — public read.
    match /pages/{id}           { allow read: if true; allow create, update: if isContentManager() && belongsToTenant(request.resource.data); allow delete: if isContentManager() && belongsToTenant(resource.data); }
    match /sections/{id}        { allow read: if true; allow create, update: if isContentManager() && belongsToTenant(request.resource.data); allow delete: if isContentManager() && belongsToTenant(resource.data); }
    // menuItems/categories: navigation + select metadata. menuItems is read by the
    // app shell's menu store (ungated); categories are CMS select-lists. Low
    // sensitivity, kept public-readable; writes are content-role gated.
    match /categories/{id}      { allow read: if true; allow create, update: if isContentManager() && belongsToTenant(request.resource.data); allow delete: if isContentManager() && belongsToTenant(resource.data); }
    match /menuItems/{id}       { allow read: if true; allow create, update: if isContentManager() && belongsToTenant(request.resource.data); allow delete: if isContentManager() && belongsToTenant(resource.data); }
    // tags/orgs/resources: NOT public. Read only by authenticated tenant members
    // (AppStore loads them post-login). The static websites get any org info via
    // the publicApi CF, never by reading these collections directly. (M-7)
    match /tags/{id}            { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /orgs/{id}            { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /resources/{id}       { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }

    // ============================================================================
    //  Users — own doc, with role/tenant/personKey escalation blocked. (C-1)
    // ============================================================================

    match /users/{userId} {
      // Read your own doc; admins/privileged may read others within their tenant.
      allow read: if signedIn() && (request.auth.uid == userId
                    || (isPrivileged() && belongsToTenant(resource.data)));

      // Self-service create of your own doc is allowed only without elevated roles;
      // admins may create within their tenant. (User provisioning normally happens
      // via the Admin SDK, which bypasses rules.)
      allow create: if signedIn() && (
                       (request.auth.uid == userId
                          && !request.resource.data.roles.get('admin', false)
                          && !request.resource.data.roles.get('privileged', false))
                       || (isAdmin() && belongsToTenant(request.resource.data))
                    );

      // Update your own doc but NOT roles / tenants / personKey; admins may update.
      allow update: if signedIn() && (
                       (request.auth.uid == userId
                          && !request.resource.data.diff(resource.data).affectedKeys()
                                .hasAny(['roles', 'tenants', 'personKey']))
                       || isAdmin()
                    );

      allow delete: if isAdmin();

      // FCM push tokens are owned by the user. (C-1 — previously any authed user
      // could read/write anyone's tokens via the catch-all.)
      match /fcmTokens/{tokenId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    // ============================================================================
    //  Tenant-scoped, client-writable collections.
    //  Phase 1: any authenticated member of the document's tenant. Per-collection
    //  role tightening (memberAdmin for persons, treasurer for accounting, …) is
    //  Phase 2.
    // ============================================================================

    match /accounting-configs/{id} { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /accounts/{id}           { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /activities/{id}         { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /addresses/{id}          { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /avatars/{id}            { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /calendars/{id}          { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /calevents/{id}          { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /comments/{id}           { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /docs/{id}               { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /folders/{id}            { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /groups/{id}             { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /i18nTenantOverride/{id} { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /icons/{id}              { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /invitations/{id}        { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /locations/{id}          { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /memberships/{id}        { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /ownerships/{id}         { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /personal-rels/{id}      { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /persons/{id}            { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }  // C-2: no longer public
    match /reservations/{id}       { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /scs-memberfees/{id}     { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /tasks/{id}              { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /transfers/{id}          { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /websiteContent/{id}     { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }
    match /workrels/{id}           { allow read: if tenantRead(); allow create, update: if tenantCreate(); allow delete: if tenantDelete(); }

    // ============================================================================
    //  Read-only on the client (written by Cloud Functions / bexio sync / seed).
    //  Tenant-scoped read; writes denied. If an admin UI legitimately writes one
    //  of these, switch its write to: isPrivileged() && belongsToTenant(request.resource.data)
    // ============================================================================

    match /asset-movements/{id}    { allow read: if tenantRead(); allow write: if false; }
    match /bills/{id}              { allow read: if tenantRead(); allow write: if false; }
    match /booking-lines/{id}      { allow read: if tenantRead(); allow write: if false; }
    match /bookings/{id}          { allow read: if tenantRead(); allow write: if false; }
    match /exchange-rates/{id}    { allow read: if tenantRead(); allow write: if false; }
    match /expense-documents/{id} { allow read: if tenantRead(); allow write: if false; }
    match /expenses/{id}          { allow read: if tenantRead(); allow write: if false; }
    match /invoice-positions/{id} { allow read: if tenantRead(); allow write: if false; }
    match /invoices/{id}          { allow read: if tenantRead(); allow write: if false; }
    match /journallogs/{id}       { allow read: if tenantRead(); allow write: if false; }
    match /payment-orders/{id}    { allow read: if tenantRead(); allow write: if false; }
    match /payments/{id}          { allow read: if tenantRead(); allow write: if false; }
    match /trips/{id}             { allow read: if tenantRead(); allow write: if false; }
    match /i18nDefault/{id}       { allow read: if tenantRead(); allow write: if false; }
    match /swissCities/{id}       { allow read: if tenantRead(); allow write: if false; }

    // Reference data that may have an admin authoring UI — allow privileged writes.
    match /assets/{id}             { allow read: if tenantRead(); allow create, update: if isPrivileged() && tenantCreate(); allow delete: if isPrivileged() && tenantDelete(); }
    match /asset-categories/{id}   { allow read: if tenantRead(); allow create, update: if isPrivileged() && tenantCreate(); allow delete: if isPrivileged() && tenantDelete(); }
    match /competition-levels/{id} { allow read: if tenantRead(); allow create, update: if isPrivileged() && tenantCreate(); allow delete: if isPrivileged() && tenantDelete(); }
    match /formDefinitions/{id}    { allow read: if tenantRead(); allow create, update: if isPrivileged() && tenantCreate(); allow delete: if isPrivileged() && tenantDelete(); }
    match /periods/{id}            { allow read: if tenantRead(); allow create, update: if isPrivileged() && tenantCreate(); allow delete: if isPrivileged() && tenantDelete(); }
    match /responsibilities/{id}   { allow read: if tenantRead(); allow create, update: if isPrivileged() && tenantCreate(); allow delete: if isPrivileged() && tenantDelete(); }
    match /vat-codes/{id}          { allow read: if tenantRead(); allow create, update: if isPrivileged() && tenantCreate(); allow delete: if isPrivileged() && tenantDelete(); }

    // ============================================================================
    //  Templates (PDF) — role-gated; converted from dead claim checks to get()-roles.
    // ============================================================================

    match /templates/{templateId} {
      allow read:          if userExists() && belongsToTenant(resource.data);
      allow create, update: if isPrivileged() || hasRole('contentAdmin');
      allow delete:        if isAdmin();

      match /versions/{versionId} {
        allow read:   if signedIn();
        allow create: if isPrivileged() || hasRole('contentAdmin');
        allow update: if (isPrivileged() || hasRole('contentAdmin')) && resource.data.status == 'draft';
        allow delete: if false;
      }
    }

    // ============================================================================
    //  Cloud-Function-owned collections (read constrained, writes denied).
    // ============================================================================

    match /docGenerations/{genId} {
      allow read:  if signedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if false;
    }
    match /_rateLimits/{docId} {
      allow read, write: if false;
    }
    match /stats_boats/{boatKey}/years/{year} {
      allow read:  if signedIn();
      allow write: if false;
    }
    match /stats_members/{memberKey}/years/{year} {
      allow read:  if signedIn();
      allow write: if false;
    }
    match /esignList/{esignId} {
      // esign records carry a singular tenantId field (not a tenants[] array).
      allow read:  if userExists() && callerTenants().hasAny([resource.data.tenantId]);
      allow write: if false;
    }
    match /esignAudit/{tenantId}/{subcollection=**} {
      allow read, write: if false;
    }

    // ============================================================================
    //  Applications — anonymous membership submissions (shape-constrained), with
    //  privileged review. (C-1 catch-all removal also makes this flow actually
    //  work — the previous undefined helper functions failed closed. M-11.)
    // ============================================================================

    match /applications/{appId} {
      allow read:   if isPrivileged() && belongsToTenant(resource.data);
      allow create: if request.resource.data.state == 'applied'
                     && request.resource.data.taskKey == ''
                     && request.resource.data.personKey == ''
                     && request.resource.data.tenants.size() == 1;
      allow update: if isPrivileged() && belongsToTenant(resource.data);
      allow delete: if false;
    }

    // ============================================================================
    //  Sessions — anonymous sessions created pre-auth, upgraded after login. (M-8)
    // ============================================================================

    match /sessions/{sessionId} {
      allow read:   if signedIn();
      // Anonymous create: inactive userKey, single tenant.
      allow create: if request.resource.data.isActive == true
                     && request.resource.data.userKey == ''
                     && request.resource.data.tenants.size() == 1;
      // Update must not change the tenant, and must NOT forge userKey:
      // either userKey is unchanged (heartbeat / end-session) or it is being set
      // to the authenticated caller's own uid (login upgrade). (M-8)
      allow update: if resource.data.tenants == request.resource.data.tenants
                     && (
                          request.resource.data.userKey == resource.data.userKey
                          || (signedIn() && request.resource.data.userKey == request.auth.uid)
                        );
      allow delete: if false;
    }

    // ============================================================================
    //  Default deny — no catch-all grant. Any collection not matched above is
    //  denied. (C-1: the previous `match /{document=**} { allow read, write:
    //  if request.auth != null }` is removed entirely.)
    // ============================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
