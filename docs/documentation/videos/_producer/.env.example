# Azure Speech (Cognitive Services) — create a "Speech" resource in the Azure portal.
# Copy this file to .env and fill in. .env is git-ignored — never commit real keys.
SPEECH_KEY=your-azure-speech-key
SPEECH_REGION=switzerlandnorth
# Swiss-German neural voices: de-CH-LeniNeural (f), de-CH-JanNeural (m).
# High-German alternatives: de-DE-SeraphinaMultilingualNeural, de-DE-KatjaNeural.
SPEECH_VOICE=de-CH-LeniNeural
