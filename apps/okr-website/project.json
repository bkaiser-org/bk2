{
  "name": "okr-website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/okr-website",
  "tags": ["type:app", "platform:web"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "serve apps/okr-website -l 4200"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/okr-website"],
      "options": {
        "parallel": false,
        "commands": [
          "rm -rf dist/apps/okr-website",
          "mkdir -p dist/apps/okr-website",
          "cp apps/okr-website/*.html dist/apps/okr-website/",
          "cp -R apps/okr-website/assets dist/apps/okr-website/assets"
        ]
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "firebase deploy --only hosting:okr-website-54aef"
      }
    }
  }
}
