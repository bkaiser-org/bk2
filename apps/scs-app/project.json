{
  "name": "scs-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "bk",
  "sourceRoot": "apps/scs-app/src",
  "tags": [
    "type:app",
    "platform:mobile",
    "platform:web"
  ],
  "targets": {
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write ."
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check ."
      }
    },
    "config": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "NODE_ENV=development node ./set-env.js"
      },
      "configurations": {
        "production": {
          "command": "NODE_ENV=production node ./set-env.js"
        }
      }
    },
    "build": {
      "dependsOn": [
        "config",
        "^build"
      ],
      "executor": "@angular/build:application",
      "inputs": [
        "production",
        "^production",
        "{workspaceRoot}/apps/scs-website/**/*"
      ],
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/scs-app",
        "index": "apps/scs-app/src/index.html",
        "browser": "apps/scs-app/src/main.ts",
        "polyfills": [],
        "tsConfig": "apps/scs-app/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/scs-app/src/assets",
          {
            "glob": "**/*",
            "input": "apps/scs-website",
            "output": "./web"
          },
