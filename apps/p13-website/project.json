{
  "name": "p13-website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/p13-website",
  "tags": ["type:app", "platform:web"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "serve apps/p13-website -l 4200"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/p13-website"],
      "options": {
        "parallel": false,
        "commands": [
          "rm -rf dist/apps/p13-website",
          "mkdir -p dist/apps/p13-website",
          "cp apps/p13-website/*.html dist/apps/p13-website/"
        ]
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "firebase deploy --only hosting:p13-website-54aef"
      }
    }
  }
}
